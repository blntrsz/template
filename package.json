{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "template",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "!packages/rules"
    ],
    "catalog": {
      "@effect/atom-react": "4.0.0-beta.70",
      "@effect/platform-node-shared": "4.0.0-beta.70",
      "@effect/sql-sqlite-bun": "4.0.0-beta.70",
      "@effect/sql-sqlite-node": "4.0.0-beta.70",
      "effect": "4.0.0-beta.70",
      "scheduler": "^0.27.0",
      "ulid": "^3.0.2"
    }
  },
  "type": "module",
  "devDependencies": {
    "@ast-grep/cli": "^0.42.0",
    "@types/bun": "^1.2.14",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "rev-dep": "^2.13.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13",
  "sherif": {
    "ignoreRule": [
      "non-existant-packages"
    ]
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}
